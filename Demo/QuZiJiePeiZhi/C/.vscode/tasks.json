{
    "tasks": [ //配置环境：用于生成活动文件
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "E:\\mingw64\\bin\\gcc.exe", //编译器路径
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                // "${file}", //当前文件进行编译,改为下一行
                "*.c", //当前文件夹所有的.c文件都编译 ！！！多文件进行编译运行和调试
                "-o",
                // "${fileDirname}\\${fileBasenameNoExtension}.exe" //生成的当前文件夹下的可执行文件名（不带拓展名），改为下一行
                "${fileDirname}\\a.exe" //生成的新的可执行程序名称
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}